{
  "name": "Design",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --cwd apps/client dev\"",
    "build": "bun run --cwd apps/client build",
    "db:migrate": "bun run --cwd apps/client migrate",
    "db:generate": "bun run --cwd apps/client generate",
    "db:studio": "bun run --cwd apps/client studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
}