generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  UPLOADTHINGS
  CFR2
  AWSS3
}

model AccessKey {
  id    String  @id @default(uuid())
  key   String  @unique
  block Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Design {
  id          String  @id @default(uuid())
  key         String  @unique
  title       String
  description String?

  provider Provider @default(AWSS3)

  createdAt DateTime @default(now())
  updatedAt DateTime
}
